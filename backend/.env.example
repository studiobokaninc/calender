# Dify API設定（ダッシュボード・管理者用）
DIFY_API_KEY=your_dify_api_key_here
DIFY_API_URL=http://your-dify-server/v1
DIFY_USER=your_email@example.com

# 一般ユーザー専用チャット用（専用チャットページで使用）
DIFY_API_KEY_USER=your_dify_api_key_for_general_users
# 未設定の場合は DIFY_API_URL / DIFY_USER を流用
# DIFY_API_URL_USER=
# DIFY_USER_USER=

# セキュリティ設定
SECRET_KEY=your_secret_key_here_change_in_production

# CLI/MCPバイパストークン（Score CLI・MCP用。ブラウザでは使用しない）
# CLI_BYPASS_TOKEN=your_cli_bypass_token_here

# 監査ログREST専用サービストークン（/api/audit/logs のみ使用。MCPのget_eventsはDB直読みのため不要）
# CALENDER_SERVICE_TOKEN=your_calender_service_token_here

# CORS設定
# ローカル開発のみの場合:
# CORS_ORIGINS=http://localhost:5175

# ローカルネットワークからのアクセスを許可する場合:
# CORS_ORIGINS=http://localhost:5175,http://192.168.1.100:5175

# 外部アクセスを許可する場合（開発環境のみ、本番環境では非推奨）:
# CORS_ALLOW_ALL=true
# または特定のオリジンのみ許可:
# CORS_ORIGINS=http://localhost:5175,http://your-external-ip:5175

# トークン有効期限（分）
ACCESS_TOKEN_EXPIRE_MINUTES=120

# ローカルLLM設定 (Ollama, scripts/generate_ai_insights.py / 議事録解析)
# LLM_PROVIDER=local に設定するとOllamaを使用 (cloud APIキー不要)
# LLM_PROVIDER=local
# LOCAL_LLM_BASE_URL=http://localhost:11434/v1
# LOCAL_LLM_MODEL=qwen2.5:7b

# ローカルWhisper設定 (音声書き起こし)
# WHISPER_BACKEND=auto  # auto=Cloud優先→ローカルfallback / local=ローカル強制
# WHISPER_MODEL=medium  # tiny/base/small/medium/large (大きいほど高精度・遅い)
