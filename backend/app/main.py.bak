@app.get("/api/users", response_model=List[Dict[str, Any]])
async def get_users_endpoint(db: Session = Depends(get_db), current_user: models.User = Depends(get_current_user), skip: int = 0, limit: int = 100):
    # 権限チェック（例：管理者のみ）
    # if current_user.get("role") != "admin":
    #     raise HTTPException(status_code=status.HTTP_403_FORBIDDEN, detail="Not authorized")
    users_db = crud.get_users(db=db, skip=skip, limit=limit)
    # 手動でレスポンス形式を調整
    response_data = []
    for user in users_db:
        user_data = schemas.UserResponse.from_orm(user).dict()
        user_data['full_name'] = user_data.pop('name', None) # name を full_name にリネーム
        response_data.append(user_data)
    return response_data

